{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "crons": [
    {
      "path": "/_/backend/api/cron/tier-check",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/_/backend/api/cron/employee-of-week",
      "schedule": "0 3 * * 1"
    }
  ]
}
