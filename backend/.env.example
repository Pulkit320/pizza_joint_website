# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection (PostgreSQL)
# For local dev, use individual variables or DATABASE_URL. For production (Vercel), DATABASE_URL is preferred.
DATABASE_URL=postgresql://postgres:pizza@localhost:5432/pizza_joint_db?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pizza_joint_db
DB_USER=
DB_PASSWORD=

# Authentication Config
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Loyalty Programme Config
LOYALTY_POINTS_PER_RUPEE=0.1
LOYALTY_REDEMPTION_RATE=10
LOYALTY_EXPIRY_MONTHS=12

# Cron Security Config
CRON_SECRET=

